  row.addEventListener(\'mousedown\', e => { stopInertia(); isDown = true; row.classList.add(\'dragging\'); startX = e.pageX - row.offsetLeft; scrollLeft = row.scrollLeft; lastX = e.pageX; lastTime = Date.now(); velocity = 0; });\n  row.addEventListener(\'mousemove\', e => { if (!isDown) return; e.preventDefault(); const x = e.pageX - row.offsetLeft; row.scrollLeft = scrollLeft - (x - startX); const now = Date.now(), dt = now - lastTime; if (dt > 0) { velocity = (e.pageX - lastX) / dt * 16; lastX = e.pageX; lastTime = now; } });\n  function release() { if (!isDown) return; isDown = false; row.classList.remove(\'dragging\'); if (Math.abs(velocity) > 0.5) animId = requestAnimationFrame(inertiaScroll); }\n  row.addEventListener(\'mouseup\', release);\n  row.addEventListener(\'mouseleave\', release);\n\n  function updateScrollMask() {\n    const canLeft = row.scrollLeft > 0;\n    const canRight = row.scrollLeft + row.clientWidth < row.scrollWidth - 1;\n    row.classList.toggle(\'can-scroll-left\', canLeft);\n    row.classList.toggle(\'can-scroll-right\', canRight);\n  }\n  row.addEventListener(\'scroll\', updateScrollMask, { passive: true });\n  new ResizeObserver(updateScrollMask).observe(row);\n  requestAnimationFrame(updateScrollMask);\n});\n\n// === SIDEBAR ACTIVE LINK ===\n(function setupSidebar() {\n  const links = Array.from(document.querySelectorAll(\'.sidebar nav a\'));\n  if (!links.length) return;\n  const linkMap = new Map();\n  const sections = [];\n  links.forEach(a => {\n    const id = a.getAttribute(\'href\').slice(1);\n    const el = document.getElementById(id);\n    if (el) { linkMap.set(id, a); sections.push(el); }\n  });\n  if (!sections.length) return;\n  let currentId = null;\n  let queued = false;\n  let clickLockUntil = 0;\n  function setActive(id) {\n    if (id === currentId) return;\n    currentId = id;\n    links.forEach(a => a.classList.toggle(\'active\', a === linkMap.get(id)));\n  }\n  function update() {\n    queued = false;\n    if (Date.