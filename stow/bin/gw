#!/usr/bin/env bash

# Git worktrees mapped to branches, sorted by commit date.
# ✓ = branch merged into base, → = the current worktree, 🔒 = locked.
# Usage:
#   gw                 list worktrees
#   gw prune           remove worktrees (and branches) for merged branches
#   gw switch <branch> print the worktree path for a branch (the gw shell
#                      function wraps this to actually cd there)

set -e

RESET=$'\033[0m'
BRIGHT=$'\033[1m'
GRAY=$'\033[90m'
LIGHT_GRAY=$'\033[38;5;246m'
GREEN=$'\033[32m'
YELLOW=$'\033[33m'
DIM_GREEN=$'\033[2;32m'
RED=$'\033[31m'
CYAN=$'\033[36m'

truncate() {
  local str="$1" max="$2"
  if [[ ${#str} -gt $max ]]; then
    printf '%s' "${str:0:$max}…"
  else
    printf '%s' "$str"
  fi
}

# Base branch to test "merged" against (main, else master).
base=main
git show-ref --verify --quiet refs/heads/main || base=master

this_wt=$(git rev-parse --show-toplevel 2>/dev/null)

# Parse `git worktree list --porcelain` into "path|branch|sha|locked" records.
# Full sha kept for exact matching against the batched git log below.
records=$(git worktree list --porcelain 2>/dev/null | awk '
  /^worktree /  { path=substr($0,10) }
  /^HEAD /      { sha=substr($0,6) }
  /^branch /    { br=substr($0,8); sub(/^refs\/heads\//,"",br) }
  /^detached/   { br="(detached)" }
  /^locked/     { locked="🔒" }
  /^$/          { if(path){print path"|"br"|"sha"|"locked}; path="";br="";sha="";locked="" }
  END           { if(path){print path"|"br"|"sha"|"locked} }
')

# Main repo directory: the primary worktree is always listed first.
first_record=${records%%$'\n'*}
repo_dir=${first_record%%|*}

nl=$'\n'

# One git log for all worktree HEADs: "sha|timestamp|relative|subject" lines.
commit_info=$(git log --no-walk=unsorted --pretty=format:'%H|%ct|%cr|%s' \
  $(printf '%s\n' "$records" | cut -d'|' -f3 | sort -u) 2>/dev/null) || commit_info=""

# Branches merged into base, one call instead of one merge-base per worktree.
merged_set="$nl$(git for-each-ref --merged="$base" --format='%(refname:short)' refs/heads 2>/dev/null)$nl"

# Attach commit timestamp for sorting.
declare -a rows=()
while IFS='|' read -r path branch sha locked; do
  [[ -z "$path" ]] && continue
  if [[ "$nl$commit_info" =~ "$nl$sha|"([^$nl]*) ]]; then
    ts="${BASH_REMATCH[1]}"
  else
    ts="0|?|"
  fi
  rows+=("$ts|$path|$branch|${sha:0:7}|$locked")
done <<<"$records"

sorted=$(printf '%s\n' "${rows[@]}" | sort -t'|' -k1 -n)

# Paths inside the repo dir show as ./relative; ones outside show the full tilde path.
short_path() {
  local p="$1"
  if [[ "$p" == "$repo_dir"/* ]]; then
    printf './%s' "${p#"$repo_dir"/}"
  else
    printf '%s' "${p/#$HOME/\~}"
  fi
}

# A branch is prunable when it's merged into base and isn't base or the current worktree.
is_merged() {
  local branch="$1" path="$2"
  [[ "$branch" == "$base" || "$path" == "$this_wt" || "$branch" == "(detached)" ]] && return 1
  [[ "$merged_set" == *"$nl$branch$nl"* ]]
}

cmd_list() {
  local max_branch_len=0 sp cols indent
  while IFS='|' read -r _ _ _ path branch _ _; do
    [[ -z "$path" ]] && continue
    [[ ${#branch} -gt $max_branch_len ]] && max_branch_len=${#branch}
  done <<<"$sorted"

  cols=${COLUMNS:-$(tput cols 2>/dev/null || echo 100)}
  # Message line is indented to the branch column:
  # lock(3) + timeago(14) + 2 + marker(1) + 2 + sha(7) + 2.
  indent=$(printf '%31s' '')

  local timeago message path branch sha locked merged is_current marker sha_color branch_color
  while IFS='|' read -r _ timeago message path branch sha locked; do
    [[ -z "$path" ]] && continue

    merged=""
    is_merged "$branch" "$path" && merged="1"
    is_current=""
    [[ "$path" == "$this_wt" ]] && is_current="1"

    if [[ -n "$is_current" ]]; then
      marker="→"
    elif [[ -n "$merged" ]]; then
      marker="${GREEN}✓${RESET}"
    else
      marker=" "
    fi

    sha_color="$YELLOW"
    [[ -n "$is_current" ]] && sha_color="$BRIGHT"

    branch_color="$GREEN"
    [[ "$branch" == "(detached)" ]] && branch_color="$DIM_GREEN"

    # Leading lock column: 🔒 renders ~2 cols; pad absent locks to match, +1 separator.
    [[ -n "$locked" ]] && lockmark="🔒" || lockmark="  "

    printf '%s %b%-14s%b  %s  %b%s%b  %b%-*s%b  %b%s%b\n' \
      "$lockmark" \
      "$GRAY" "$(truncate "$timeago" 14)" "$RESET" \
      "$marker" \
      "$sha_color" "$sha" "$RESET" \
      "$branch_color" "$max_branch_len" "$branch" "$RESET" \
      "$CYAN" "$(short_path "$path")" "$RESET"

    printf '%s%b%s%b\n' "$indent" \
      "$LIGHT_GRAY" "$(truncate "$message" $((cols - 31)))" "$RESET"
  done <<<"$sorted"
}

remove_wt() {
  local path="$1" branch="$2"
  git worktree unlock "$path" 2>/dev/null || true
  git worktree remove --force "$path"
  [[ -n "$branch" && "$branch" != "(detached)" ]] && git branch -D "$branch"
}

cmd_prune() {
  local -a unlocked=() locked=()
  local path branch sha lock
  while IFS='|' read -r _ _ _ path branch sha lock; do
    [[ -z "$path" ]] && continue
    is_merged "$branch" "$path" || continue
    if [[ -n "$lock" ]]; then
      locked+=("$path|$branch")
    else
      unlocked+=("$path|$branch")
    fi
  done <<<"$sorted"

  if [[ ${#unlocked[@]} -eq 0 && ${#locked[@]} -eq 0 ]]; then
    echo "Nothing to prune — no merged worktrees."
    return
  fi

  local entry p b
  echo "${BRIGHT}Merged worktrees to remove (branch will be deleted too):${RESET}"
  for entry in "${unlocked[@]}"; do
    IFS='|' read -r p b <<<"$entry"
    printf '  %b%s%b  %b%s%b\n' "$GREEN" "$b" "$RESET" "$CYAN" "$(short_path "$p")" "$RESET"
  done
  for entry in "${locked[@]}"; do
    IFS='|' read -r p b <<<"$entry"
    printf '  🔒 %b%s%b  %b%s%b\n' "$GREEN" "$b" "$RESET" "$CYAN" "$(short_path "$p")" "$RESET"
  done
  echo

  local reply targets=()
  if [[ ${#locked[@]} -gt 0 ]]; then
    printf 'Remove merged [%by%b], all merged incl. %b🔒 locked%b [%ba%b], or cancel [%bn%b]? ' \
      "$GREEN" "$RESET" "$RED" "$RESET" "$YELLOW" "$RESET" "$GRAY" "$RESET"
    read -r reply
    case "$reply" in
      y|Y) targets=("${unlocked[@]}") ;;
      a|A) targets=("${unlocked[@]}" "${locked[@]}") ;;
      *)   echo "Cancelled."; return ;;
    esac
  else
    printf 'Remove these %d worktree(s)? [%by%b/%bn%b] ' \
      "${#unlocked[@]}" "$GREEN" "$RESET" "$GRAY" "$RESET"
    read -r reply
    case "$reply" in
      y|Y) targets=("${unlocked[@]}") ;;
      *)   echo "Cancelled."; return ;;
    esac
  fi

  for entry in "${targets[@]}"; do
    IFS='|' read -r p b <<<"$entry"
    echo "Removing ${b} (${p})…"
    remove_wt "$p" "$b"
  done
  git worktree prune
  echo "Done."
}

# Print the worktree path for a branch. The gw shell function (shell/functions.sh)
# cds to this output; a script can't change its parent shell's directory.
cmd_switch() {
  local target="$1" path branch sha
  if [[ -z "$target" ]]; then
    echo "Usage: gw switch <branch|sha>" >&2
    return 1
  fi
  while IFS='|' read -r path branch sha _; do
    # Match branch name, or a sha prefix (stored sha is full length).
    if [[ "$branch" == "$target" || "$sha" == "$target"* ]]; then
      printf '%s\n' "$path"
      return 0
    fi
  done <<<"$records"
  echo "No worktree for branch or sha '$target'" >&2
  return 1
}

usage() {
  cat <<EOF
${BRIGHT}gw${RESET} — list git worktrees mapped to their branches, sorted by commit date.

${BRIGHT}Usage:${RESET}
  gw            List worktrees. ${GREEN}✓${RESET} merged into ${base}, → current, 🔒 locked.
  gw prune      Remove worktrees (and delete branches) for merged branches.
                Prompts before removing; if any are 🔒 locked, choose
                [y] merged only, [a] all incl. locked, or [n] cancel.
  gw switch <branch|sha>
                cd to the worktree for <branch>, or by sha prefix for
                detached worktrees (via the gw shell function; the script
                itself just prints the path).
  gw -h, --help Show this help.
EOF
}

case "${1:-list}" in
  prune)        cmd_prune ;;
  switch)       cmd_switch "$2" ;;
  list)         cmd_list ;;
  -h|--help|help) usage ;;
  *)            usage >&2; exit 1 ;;
esac
