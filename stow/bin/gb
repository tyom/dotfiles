#!/usr/bin/env bash

# Git branches with formatted output, sorted by commit date
# Usage: gb [-r]

set -e

# Colors (using $'...' syntax for proper escape interpretation)
RESET=$'\033[0m'
BRIGHT=$'\033[1m'
GRAY=$'\033[90m'
LIGHT_GRAY=$'\033[38;5;246m'
GREEN=$'\033[32m'
YELLOW=$'\033[33m'
WHITE=$'\033[37m'

truncate() {
  local str="$1"
  local max="$2"
  if [[ ${#str} -gt $max ]]; then
    printf '%s' "${str:0:$max}…"
  else
    printf '%s' "$str"
  fi
}

refs=refs/heads
[[ "${1:-}" == "-r" ]] && refs=refs/remotes

# One call for everything: sorted, subject last so embedded '|' can't break
# fields, symref first to skip pointers like origin/HEAD
sorted_data=$(git for-each-ref --sort=committerdate \
  --format='%(symref)|%(refname:short)|%(objectname:short)|%(authorname)|%(committerdate:relative)|%(contents:subject)' \
  "$refs" 2>/dev/null) || exit 0

[[ -z "$sorted_data" ]] && exit 0

current_branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)

# Branches whose tip is an ancestor of HEAD, one call instead of one per branch
merged=$'\n'$(git for-each-ref --merged=HEAD --format='%(refname:short)' "$refs" 2>/dev/null)$'\n'

# Calculate max branch name length
max_branch_len=0
while IFS='|' read -r symref branch _; do
  [[ -n "$symref" ]] && continue
  [[ ${#branch} -gt $max_branch_len ]] && max_branch_len=${#branch}
done <<<"$sorted_data"

# Output
while IFS='|' read -r symref branch sha author timeago message; do
  [[ -z "$branch" || -n "$symref" ]] && continue

  is_present=""
  [[ "$merged" == *$'\n'"$branch"$'\n'* ]] && is_present="1"

  is_current=""
  [[ "$branch" == "$current_branch" ]] && is_current="1"

  # Determine marker
  if [[ -n "$is_current" ]]; then
    marker="→"
  elif [[ -n "$is_present" ]]; then
    marker="${GREEN}✓${RESET}"
  else
    marker=" "
  fi

  # Determine SHA color
  if [[ -n "$is_present" && -n "$is_current" ]]; then
    sha_color="$BRIGHT"
  else
    sha_color="$YELLOW"
  fi

  # Truncate fields
  timeago_trunc=$(truncate "$timeago" 20)
  author_trunc=$(truncate "$author" 20)
  message_trunc=$(truncate "$message" 60)

  # Use %b to interpret escape sequences in format string
  printf '%b%-20s%b  %b%-20s%b  %s  %b%s%b  %b%-*s%b  %b%s%b\n' \
    "$GRAY" "$timeago_trunc" "$RESET" \
    "$WHITE" "$author_trunc" "$RESET" \
    "$marker" \
    "$sha_color" "$sha" "$RESET" \
    "$GREEN" "$max_branch_len" "$branch" "$RESET" \
    "$LIGHT_GRAY" "$message_trunc" "$RESET"
done <<<"$sorted_data"
